{
  "name": "geef",
  "version": "0.1.0",
  "private": true,
  "description": "A local GIF library for the Chrome side panel.",
  "type": "module",
  "files": [
    "LICENSE",
    "manifest.json",
    "src",
    "store-assets/icons"
  ],
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pack:extension": "node scripts/pack-extension.mjs",
    "postpack": "node scripts/pack-extension.mjs --remove-pnpm-tarball"
  },
  "devDependencies": {
    "prettier": "^3.9.5",
    "archiver": "^8.0.0"
  },
  "packageManager": "pnpm@11.11.0"
}
