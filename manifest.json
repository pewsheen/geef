{
  "manifest_version": 3,
  "name": "Geef",
  "description": "Browse, organize, convert, and paste GIFs into editable web inputs.",
  "version": "0.2.0",
  "minimum_chrome_version": "116",
  "permissions": ["activeTab", "sidePanel", "scripting", "storage"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Geef"
  },
  "icons": {
    "16": "store-assets/icons/icon-16.png",
    "32": "store-assets/icons/icon-32.png",
    "48": "store-assets/icons/icon-48.png",
    "128": "store-assets/icons/icon-128.png"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  }
}
